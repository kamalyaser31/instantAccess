msgstr "错误：无法打开文件夹"

msgid "Error: Could not open the file"
msgstr "错误：无法打开文件"

msgid "Error: Could not start the program"
msgstr "错误：无法启动程序"

#, python-brace-format
msgid "{action}: {preview}"
msgstr "{action}：{preview}"

msgid "Set shortcut"
msgstr "设置快捷键"

msgid "Press the desired shortcut key. Escape cancels."
msgstr "请按下要设置的快捷键，按 Esc 取消。"

