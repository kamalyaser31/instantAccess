msgid "Type"
msgstr "类型"

msgid "Delay before executing this action"
msgstr "执行此操作前等待（秒）"

msgid "Path or URL"
msgstr "路径或网址"

msgid "Browse"
msgstr "浏览"

msgid "Arguments (optional)"
msgstr "参数（可选）"

